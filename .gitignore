# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Cargo local config
.cargo/config.local.toml

# IDE
.idea/
.vscode/
*.iml
*.swp
*.swo

# Logs / runtime
logs/
*.log

# OS / temp
.DS_Store
Thumbs.db
*.tmp

# Local env / secrets
.env
.env.local
.env.*.local

# Recordings (project produces audio + transcripts at runtime)
/recordings/

# Coverage reports
*.profraw
/coverage/
/tarpaulin-report.html

# Local tooling caches (Claude Code, claude-mem, etc.)
/.cache/
/.claude/

# makepkg build artifacts: `makepkg -f` extracts the upstream
# tarball into packaging/arch/src/, stages the install tree under
# packaging/arch/pkg/, and drops .tar.gz / .pkg.tar.zst alongside.
# All three are reproducible and must never land in version control.
/packaging/arch/src/
/packaging/arch/pkg/
/packaging/arch/*.tar.gz
/packaging/arch/*.pkg.tar.zst
