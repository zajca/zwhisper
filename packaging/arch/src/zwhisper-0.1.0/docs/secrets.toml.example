# zwhisper secrets file
#
# Copy to ~/.config/zwhisper/secrets.toml and chmod 600.
# Permissions check rejects anything other than mode 0600 or 0400.
# The parent directory ~/.config/zwhisper/ MUST also not be group/other writable.
#
# The daemon resolves API keys in this order:
#   1. ZWHISPER_<BACKEND>_API_KEY environment variable
#   2. This file
#
# Keyring / secret-service integration is NOT supported in M5 — see
# docs/M5-plan.md OQ-2. Either the env var or this file must provide the
# key for any cloud-backed profile to work.

[deepgram]
# Get a key at https://console.deepgram.com/. The default profile
# `cloud-meeting` uses the `nova-3` model.
api_key = "REPLACE_WITH_YOUR_DEEPGRAM_TOKEN"
