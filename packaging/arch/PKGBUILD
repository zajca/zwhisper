# Maintainer: Martin Zajic <martin.zajic@keboola.com>
# shellcheck disable=SC2034,SC2154
#
# zwhisper — Linux desktop voice recorder + whisper.cpp / Deepgram
# transcription frontend. Ships the CLI-only product:
#
# - zwhisperd          — D-Bus auto-activated recorder daemon
# - zwhisper           — CLI client (`zwhisper-cli` crate)

pkgname=zwhisper
pkgver=0.6.0
pkgrel=1
pkgdesc="Voice recorder daemon and CLI transcription frontend for Linux desktops"
arch=('x86_64')
url="https://github.com/zajca/zwhisper"
license=('MIT')

# Disable makepkg-injected `-flto=auto` (default `lto` in /etc/makepkg.conf
# OPTIONS). When the system LTO flag reaches ring's build.rs the C/asm
# objects are emitted as GCC LTO bitcode which rust-lld cannot resolve at
# the final Rust link step (undefined `ring_core_*` symbols). cargo handles
# LTO itself via `[profile.release] lto = "thin"` in workspace Cargo.toml,
# so opting out at the makepkg layer is the correct fix.
options=('!lto')

# Runtime dependencies. Audio path goes PipeWire -> GStreamer ->
# FLAC; the daemon claims `cz.zajca.Zwhisper1` on the session bus.
depends=(
    'gstreamer'
    'gst-plugins-base'
    'gst-plugins-good'
    'gst-plugin-pipewire'
    'pipewire'
    'wireplumber'
    'dbus'
    'libnotify'
    'gcc-libs'
    'glibc'
)

# CLI/daemon Rust build chain. Arch packages ship development files
# with the runtime packages above, so GStreamer and D-Bus headers come
# from `depends`.
makedepends=(
    'rust>=1.88'
    'cargo'
    'gcc'
    'pkgconf'
)

# Hint to namcap that whisper.cpp is an optional companion: the
# CLI will detect it via `which whisper-cli` at run time, so it is
# not a hard dependency. Cloud-only users skip it entirely.
optdepends=(
    'whisper.cpp: local Whisper inference for the on-device backend'
    'xdg-desktop-portal: optional GlobalShortcuts probing/binding via zwhisper hotkey'
    'libsecret: Secret Service support for cloud API keys (deferred post-M8)'
    'wtype: type transcripts at the cursor for the type_at_cursor output (wlroots compositors only — Sway/Hyprland; not GNOME/KWin)'
)

# Source: tag tarball from the GitHub release.  `b2sums` are
# generated at release tag time via `updpkgsums` (see
# docs/RELEASE.md). The `SKIP` placeholder here is a deliberate
# starter value — CI gates the real release on a populated b2sum.
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
b2sums=('9ea2ee68a10edb6a241ba7fb008b339b823f4fbbd69e62d34391975e8554d738d8d6ea8d54694d55ac00842e88d86d84d27bcaff5b30680bf82652e0ee836ac9')

install="$pkgname.install"

prepare() {
    cd "$pkgname-$pkgver"

    # `cargo fetch --locked` populates the cargo registry cache for
    # every workspace crate against the committed `Cargo.lock`. The
    # build step then runs with `--frozen` so any drift surfaces
    # at build time rather than at run time.
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$pkgname-$pkgver"

    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    # Reproducibility: drop debug info from the workspace release
    # profile (already configured in Cargo.toml as `strip = "symbols"`,
    # but RUSTFLAGS reinforces it for reproducible-builds tooling).
    # No `-C target-cpu=native` — packaged binaries must run on any
    # x86_64 chip, not just the build host.
    export RUSTFLAGS="-C strip=symbols"

    # `--features parakeet` compiles the in-process Parakeet ASR backend
    # into both binaries. It is default-OFF in the crates (pulls ONNX
    # Runtime via `ort`), but the shipped `dictation` profile uses
    # `backend = "parakeet"`, so without it every dictation transcribe
    # fails with "backend `parakeet` is not compiled in". The feature is
    # shared by both packages, so a single `--features` flag applies to
    # both `-p` targets.
    cargo build --frozen --release --features parakeet -p zwhisperd -p zwhisper-cli
}

check() {
    cd "$pkgname-$pkgver"

    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    # Keep package-gating tests scoped to the CLI-only product and
    # shared libraries. Integration tests that need a live PipeWire
    # bus are skipped here.
    cargo test --frozen --release -p zwhisper-core -p zwhisper-ipc --lib
    cargo test --frozen --release -p zwhisperd -p zwhisper-cli --bins
}

package() {
    cd "$pkgname-$pkgver"

    # 1. Binaries — `install -Dm755` creates the destination
    #    directory tree on demand.
    install -Dm755 "target/release/zwhisperd"        "$pkgdir/usr/bin/zwhisperd"
    install -Dm755 "target/release/zwhisper"         "$pkgdir/usr/bin/zwhisper"

    # 2. systemd user unit. `Type=dbus` means the daemon
    #    unit waits for `cz.zajca.Zwhisper1` on the session bus —
    #    the D-Bus activation file below also references it so the
    #    daemon spawns on first call from any client.
    install -Dm644 "systemd/zwhisperd.service"       "$pkgdir/usr/lib/systemd/user/zwhisperd.service"

    # 2b. Session-bound transcript-delivery consumer (RFC-daemon-role
    #     Feature 3). Bound to graphical-session.target and auto-enabled
    #     by the .install scriptlet; safe on headless hosts because the
    #     target is never reached there.
    install -Dm644 "systemd/zwhisper-deliver.service" "$pkgdir/usr/lib/systemd/user/zwhisper-deliver.service"

    # 3. D-Bus session-bus auto-activation entry.
    install -Dm644 "dbus/cz.zajca.Zwhisper1.service" "$pkgdir/usr/share/dbus-1/services/cz.zajca.Zwhisper1.service"

    # 4. Read-only configuration templates. Users copy the
    #    `.example` files into `~/.config/zwhisper/` and `chmod 600`
    #    the secrets one.
    install -Dm644 "docs/secrets.toml.example" \
        "$pkgdir/usr/share/zwhisper/secrets.toml.example"

    # 5. Documentation + license.
    install -Dm644 "README.md"     "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 "CHANGELOG.md"  "$pkgdir/usr/share/doc/$pkgname/CHANGELOG.md"
    install -Dm644 "LICENSE"       "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
